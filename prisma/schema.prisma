generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MEMBER
  OWNER
  ADMIN
}

enum CommunityStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("CourseStatus")
}

enum MembershipStatus {
  PENDING
  ACTIVE
  REMOVED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("AnnouncementStatus")
}

model User {
  id               String              @id @default(cuid())
  name             String?
  email            String?             @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  failedSignInAttempts Int             @default(0)
  signInLockedAt   DateTime?
  birthDate        DateTime?
  role             UserRole            @default(MEMBER)
  accounts         Account[]
  sessions         Session[]
  userProfile      UserProfile?
  ownedCommunities Community[]            @relation("CourseTeacher")
  communityMemberships CommunityMembership[] @relation("MembershipLearner")
  sentInvitations  CommunityInvitation[]  @relation("InvitationTeacher")
  receivedInvitations CommunityInvitation[] @relation("InvitationLearner")
  communityJoinRequests CommunityJoinRequest[] @relation("JoinRequestLearner")
  reviewedJoinRequests CommunityJoinRequest[] @relation("JoinRequestReviewer")
  posts            CommunityPost[]
  comments         Comment[]
  evaluations      CommunityEvaluation[]
  classroomItemProgress ClassroomItemProgress[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  specialty String?
  track     String?
  bio       String?  @db.Text
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("UserProfile")
}

model Community {
  id            String             @id @default(cuid())
  title         String
  slug          String             @unique
  description   String             @db.Text
  type          String
  status        CommunityStatus    @default(DRAFT)
  ownerId       String             @map("teacherId")
  owner         User               @relation("CourseTeacher", fields: [ownerId], references: [id], onDelete: Cascade)
  classroomItems ClassroomItem[]
  documents     CommunityDocument[]
  memberships   CommunityMembership[]
  invitations   CommunityInvitation[]
  accessRequests CommunityJoinRequest[]
  posts         CommunityPost[]
  evaluations   CommunityEvaluation[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([ownerId])
  @@index([status])
  @@map("Course")
}

model ClassroomItem {
  id            String           @id @default(cuid())
  communityId   String           @map("courseId")
  community     Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title         String
  content       String           @db.Text
  contentType   String
  position      Int
  progressItems ClassroomItemProgress[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([communityId, position])
  @@index([communityId])
  @@map("Lesson")
}

model CommunityMembership {
  id        String           @id @default(cuid())
  communityId  String        @map("courseId")
  memberId String            @map("learnerId")
  status    MembershipStatus @default(PENDING)
  joinedAt  DateTime         @default(now())
  endedAt   DateTime?
  community Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  member    User             @relation("MembershipLearner", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([communityId, memberId])
  @@index([memberId])
  @@index([status])
  @@map("CourseMembership")
}

model CommunityInvitation {
  id          String           @id @default(cuid())
  communityId String           @map("courseId")
  ownerId     String           @map("teacherId")
  memberId    String           @map("learnerId")
  status      InvitationStatus @default(PENDING)
  sentAt      DateTime         @default(now())
  respondedAt DateTime?
  community   Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  owner       User             @relation("InvitationTeacher", fields: [ownerId], references: [id], onDelete: Cascade)
  member      User             @relation("InvitationLearner", fields: [memberId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([ownerId])
  @@index([memberId])
  @@index([status])
  @@map("CourseInvitation")
}

model CommunityJoinRequest {
  id           String            @id @default(cuid())
  communityId  String            @map("courseId")
  memberId     String            @map("learnerId")
  status       JoinRequestStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  community    Community         @relation(fields: [communityId], references: [id], onDelete: Cascade)
  member       User              @relation("JoinRequestLearner", fields: [memberId], references: [id], onDelete: Cascade)
  reviewedBy   User?             @relation("JoinRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([communityId])
  @@index([memberId])
  @@index([status])
  @@index([reviewedById])
  @@map("CourseJoinRequest")
}

model CommunityPost {
  id          String             @id @default(cuid())
  communityId String             @map("courseId")
  authorId    String
  title       String
  content     String             @db.Text
  status      PostStatus         @default(DRAFT)
  publishedAt DateTime?
  community   Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author      User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([communityId])
  @@index([authorId])
  @@index([status])
  @@map("Announcement")
}

model Comment {
  id             String       @id @default(cuid())
  postId         String       @map("announcementId")
  authorId       String
  content        String       @db.Text
  post           CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([postId])
  @@index([authorId])
}

model CommunityEvaluation {
  id        String   @id @default(cuid())
  communityId  String @map("courseId")
  memberId String     @map("learnerId")
  rating    Int
  feedback  String?  @db.Text
  community Community   @relation(fields: [communityId], references: [id], onDelete: Cascade)
  member    User        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([communityId, memberId])
  @@index([memberId])
  @@map("CourseEvaluation")
}

model ClassroomItemProgress {
  id           String   @id @default(cuid())
  classroomItemId String @map("lessonId")
  memberId    String     @map("learnerId")
  completed    Boolean  @default(false)
  completedAt  DateTime?
  lastViewedAt DateTime?
  classroomItem ClassroomItem   @relation(fields: [classroomItemId], references: [id], onDelete: Cascade)
  member       User             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([classroomItemId, memberId])
  @@index([memberId])
  @@map("LessonProgress")
}

model CommunityDocument {
  id        String   @id @default(cuid())
  communityId  String @map("courseId")
  label     String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  community Community   @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@map("CourseDocument")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
